API_BASE_URL=https://YOUR_APIGW_ID.execute-api.us-east-1.amazonaws.com/prod/v1
# Hosted UI domain output by CDK, for example:
# https://your-prefix.auth.us-east-1.amazoncognito.com
COGNITO_DOMAIN=https://your-domain.auth.us-east-1.amazoncognito.com
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxx
REDIRECT_URI=myapp://callback
REVENUECAT_IOS_API_KEY=your_revenuecat_ios_api_key
REVENUECAT_ANDROID_API_KEY=your_revenuecat_android_api_key
REVENUECAT_ENTITLEMENT_ID=your_revenuecat_entitlement_id
META_APP_ID=your_meta_app_id
META_CLIENT_TOKEN=your_meta_client_token
META_DISPLAY_NAME=Luva
META_IOS_USER_TRACKING_PERMISSION=Usamos tu identificador publicitario para medir suscripciones y mejorar nuestras campañas en Meta. No vendemos tu informacion.
