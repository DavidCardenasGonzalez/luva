VITE_ADMIN_API_BASE_URL=https://api.example.com/prod/v1/admin
VITE_COGNITO_DOMAIN=https://your-domain.auth.us-east-1.amazoncognito.com
VITE_COGNITO_CLIENT_ID=your_cognito_client_id
# Opcional. Si no se define, usa la raiz actual del admin.
VITE_REDIRECT_URI=http://localhost:5174/

# Ejemplo de callback/logout en produccion cuando el admin ya esta publicado.
# VITE_REDIRECT_URI=https://admin.example.com/

# Publish del portal admin
# Opcional. Nombre del stack CDK/CloudFormation desde el que se leen los outputs.
LUVA_INFRA_STACK_NAME=LuvaStack
# Opcional. Perfil AWS CLI usado por npm run publish.
LUVA_AWS_PROFILE=david

# Overrides manuales opcionales para publicar sin leer outputs del stack.
# LUVA_ADMIN_PORTAL_BUCKET=your-admin-portal-bucket
# LUVA_ADMIN_PORTAL_DISTRIBUTION_ID=E1234567890ABC
# LUVA_ADMIN_PORTAL_URL=https://admin.example.com
